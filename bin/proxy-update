#!/usr/bin/env bash
# proxy-update — pull the latest proxy-config-utility and relink its commands.
#
# Updates the on-box copy of the repo, then re-symlinks the relevant bin/* into
# ~/bin (OS/tool-aware: only commands whose tool is present). Shell snippets are
# sourced from the repo, so new shells pick up changes with no action; run
# 'proxy-sync' in an already-open shell to adopt env/prompt changes now.
#
# If the repo is a git checkout it does 'git pull'; otherwise it just relinks
# (re-clone to enable pulling). Override the repo path with PROXY_REPO.
set -u
__self="${BASH_SOURCE[0]:-$0}"; [ -L "$__self" ] && __self="$(readlink "$__self")"
. "$(cd "$(dirname "$__self")/../lib" && pwd)/proxy-common.sh" || { echo "proxy-update: cannot load shared lib" >&2; exit 1; }
__pcu_init "${BASH_SOURCE[0]:-$0}"

case "${1:-}" in -h|--help) sed -n '2,9p' "$PCU_SELF"; exit 0 ;; esac

# main() so the script is fully parsed before 'git pull' can rewrite it (self-update safety).
main() {
  local REPO="${PROXY_REPO:-$PCU_REPO}"
  echo "repo: $REPO"
  if [ -d "$REPO/.git" ]; then
    echo "pulling latest..."
    git -C "$REPO" pull --ff-only || echo "proxy-update: git pull failed (offline/auth?) — relinking the current checkout anyway." >&2
  else
    echo "note: $REPO is not a git checkout — skipping pull."
    echo "      to enable pull updates, re-clone it:"
    echo "        git clone https://github.com/effndc/proxy-config-utility.git \"$REPO\""
  fi
  echo "relinking commands into ~/bin (OS/tool-aware):"
  __pcu_link_bins "$REPO" "$HOME/bin"
  echo "done. New shells are current; in open shells run 'proxy-sync' (or 'proxy-refresh' to re-detect)."
}
main "$@"
