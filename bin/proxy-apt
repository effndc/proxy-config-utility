#!/usr/bin/env bash
# proxy-apt — set/clear APT's proxy (/etc/apt/apt.conf.d/95proxy) to match proxy state.
# Self-elevates (with a notice) because the file is root-owned; no restart — apt reads
# its config each run. Just run it as your user:
#   proxy-apt on      # apt uses the proxy   (prompts for sudo)
#   proxy-apt off     # apt goes direct
# Values come from ~/.config/proxy-config/config. Test overrides: APT_PROXY_FILE, PROXY_CONFIG.
set -u
__self="${BASH_SOURCE[0]:-$0}"; [ -L "$__self" ] && __self="$(readlink "$__self")"
. "$(cd "$(dirname "$__self")/../lib" && pwd)/proxy-common.sh" || { echo "proxy-apt: cannot load shared lib" >&2; exit 1; }
__pcu_init "${BASH_SOURCE[0]:-$0}"

STATE=""
while [ $# -gt 0 ]; do
  case "$1" in
    on|proxy_yes) STATE=on ;;
    off|no_proxy) STATE=off ;;
    -h|--help) sed -n '2,8p' "$PCU_SELF"; exit 0 ;;
    *) echo "proxy-apt: unknown arg '$1' (try -h)" >&2; exit 2 ;;
  esac; shift
done
[ -z "$STATE" ] && { echo "proxy-apt: need 'on' or 'off'" >&2; exit 2; }

APT_FILE="${APT_PROXY_FILE:-/etc/apt/apt.conf.d/95proxy}"
case "$APT_FILE" in /etc/*) __pcu_need_root "write $APT_FILE (apt proxy $STATE)" "$STATE" ;; esac

__pcu_load_config
__pcu_warn_placeholder
if [ "$STATE" = on ]; then
  [ -z "$HTTP_PROXY_URL" ] && { echo "proxy-apt: HTTP_PROXY_URL not set in $PCU_CONFIG" >&2; exit 1; }
  h="$HTTP_PROXY_URL";  case "$h" in */) ;; *) h="$h/" ;; esac
  s="$HTTPS_PROXY_URL"; case "$s" in */) ;; *) s="$s/" ;; esac
  d="$(dirname "$APT_FILE")"; mkdir -p "$d"
  tmp="$(mktemp "$d/.proxy-apt.XXXXXX")"
  cat > "$tmp" <<EOF
// Managed by proxy-config-utility (proxy-apt) — toggled by proxy state; do not edit.
Acquire::http::Proxy "$h";
Acquire::https::Proxy "$s";
EOF
  chmod 644 "$tmp"; mv -f "$tmp" "$APT_FILE"
  echo "  wrote $APT_FILE (apt proxy ON)"
else
  if [ -e "$APT_FILE" ]; then rm -f "$APT_FILE"; echo "  removed $APT_FILE (apt proxy OFF)"
  else echo "  $APT_FILE already absent (apt proxy OFF)"; fi
fi
