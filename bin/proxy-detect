#!/usr/bin/env bash
# proxy-detect — detect whether you are behind a corporate proxy, then atomically
# publish a small state cache that your shells read to (a) color the prompt and
# (b) set/unset http_proxy/etc. Portable across macOS and Linux. Safe to run
# concurrently (single-instance mkdir lock).
#
# Configuration lives in ~/.config/proxy-config/config (see config/config.example).
# Run it via the `proxy-refresh` shell function, or on a schedule (macOS launchd /
# Linux systemd timer). Generic: NO site-specific values — customize the config.
set -u

# Sane PATH covering both macOS (Homebrew) and Linux locations (also lets the
# on-change hook find proxy-git/proxy-docker in ~/bin).
export PATH="/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin:$HOME/bin"

# shared lib
__self="${BASH_SOURCE[0]:-$0}"; [ -L "$__self" ] && __self="$(readlink "$__self")"
. "$(cd "$(dirname "$__self")/../lib" && pwd)/proxy-common.sh" || { echo "proxy-detect: cannot load shared lib" >&2; exit 1; }
__pcu_init "${BASH_SOURCE[0]:-$0}"

case "${1:-}" in -h|--help) sed -n '2,8p' "$PCU_SELF"; exit 0 ;; esac

OS="$(uname -s)"
STATE_DIR="$HOME/.cache/proxy"
STATE_ENV="$STATE_DIR/state.env"     # POSIX: bash & zsh source this (export/unset)
STATE_FISH="$STATE_DIR/state.fish"   # fish sources this (set -gx / set -e)
LOCK="$STATE_DIR/proxy-detect.lock"

__pcu_load_config                    # -> PROXY_PROBE_HOST/PORT, *_PROXY_URL, NO_PROXY_LIST, colors
__pcu_warn_placeholder               # nudge if config is unset/example (surfaces via proxy-refresh)
: "${PROXY_COLOR_ON:=38;5;33}"       # generic 256-color defaults (theme-independent)
: "${PROXY_COLOR_OFF:=38;5;51}"
HOOK="${PROXY_HOOK:-$HOME/.config/proxy-config/on-change}"

mkdir -p "$STATE_DIR"

# ---- portable file mtime (epoch seconds) ----
__mtime() { case "$OS" in Darwin) stat -f %m "$1" ;; *) stat -c %Y "$1" ;; esac; }

# ---- single-instance lock (mkdir is atomic everywhere; flock absent on macOS) ----
if ! mkdir "$LOCK" 2>/dev/null; then
    if [ -d "$LOCK" ]; then
        age=$(( $(date +%s) - $(__mtime "$LOCK" 2>/dev/null || echo 0) ))
        [ "$age" -gt 120 ] && rmdir "$LOCK" 2>/dev/null   # reclaim a stale lock
    fi
    mkdir "$LOCK" 2>/dev/null || exit 0   # still locked -> a peer is refreshing; bail
fi
trap 'rmdir "$LOCK" 2>/dev/null' EXIT INT TERM

# ---- reachability probe (2s budget) ----
__reachable() {  # host port
    if command -v nc >/dev/null 2>&1; then
        case "$OS" in
            Darwin) nc -z -G 2 -w 2 "$1" "$2" 2>/dev/null ;;
            *)      nc -z -w 2 "$1" "$2" 2>/dev/null ;;
        esac
    else
        ( exec 3<>"/dev/tcp/$1/$2" ) 2>/dev/null
    fi
}

if [ -n "$PROXY_PROBE_HOST" ] && __reachable "$PROXY_PROBE_HOST" "${PROXY_PROBE_PORT:-}"; then
    STATUS=proxy_yes; COLOR="$PROXY_COLOR_ON"
else
    STATUS=no_proxy;  COLOR="$PROXY_COLOR_OFF"
fi

# ---- optional user hook (e.g. git/docker-client proxy via proxy-git/proxy-docker) ----
[ -x "$HOOK" ] && "$HOOK" "$STATUS" >/dev/null 2>&1 || true

# ---- publish POSIX cache atomically (temp + rename on same filesystem) ----
tmpe="$(mktemp "$STATE_DIR/state.env.XXXXXX")" || exit 0
{
    echo "# generated by proxy-detect $(date -u +%Y-%m-%dT%H:%M:%SZ)"
    echo "PROXY_STATUS=$STATUS"
    echo "PROXY_COLOR=\"$COLOR\""
    if [ "$STATUS" = proxy_yes ]; then
        echo "export http_proxy=$HTTP_PROXY_URL"
        echo "export https_proxy=$HTTPS_PROXY_URL"
        echo "export socks_proxy=$SOCKS_PROXY_URL"
        echo "export no_proxy=\"$NO_PROXY_LIST\""
    else
        echo "unset http_proxy https_proxy socks_proxy no_proxy"
    fi
} > "$tmpe"
mv -f "$tmpe" "$STATE_ENV"

# ---- publish fish cache atomically ----
tmpf="$(mktemp "$STATE_DIR/state.fish.XXXXXX")" || exit 0
{
    echo "# generated by proxy-detect $(date -u +%Y-%m-%dT%H:%M:%SZ)"
    echo "set -gx PROXY_STATUS $STATUS"
    echo "set -gx PROXY_COLOR '$COLOR'"
    if [ "$STATUS" = proxy_yes ]; then
        echo "set -gx http_proxy '$HTTP_PROXY_URL'"
        echo "set -gx https_proxy '$HTTPS_PROXY_URL'"
        echo "set -gx socks_proxy '$SOCKS_PROXY_URL'"
        echo "set -gx no_proxy '$NO_PROXY_LIST'"
    else
        echo "set -e http_proxy; set -e https_proxy; set -e socks_proxy; set -e no_proxy"
    fi
} > "$tmpf"
mv -f "$tmpf" "$STATE_FISH"
