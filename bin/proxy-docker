#!/usr/bin/env bash
# proxy-docker — apply/remove Docker proxy settings to match proxy state.
#
#   proxy-docker on|off                # CLIENT scope (~/.docker/config.json): build/run
#                                      # container env. No sudo, no restart.
#   proxy-docker --daemon on|off       # DAEMON scope (/etc/docker/daemon.json): docker pull.
#                                      # Self-elevates (with a notice) and restarts dockerd.
#   proxy-docker on|off --all          # client now + daemon (daemon part self-elevates)
#   add --no-restart to skip the docker restart on the daemon side.
#
# Values from ~/.config/proxy-config/config. Linux/Docker-Engine for the daemon side; the
# client side is portable. Test overrides: DOCKER_CLIENT_JSON, DOCKER_DAEMON_JSON, PROXY_CONFIG.
set -u
__self="${BASH_SOURCE[0]:-$0}"; [ -L "$__self" ] && __self="$(readlink "$__self")"
. "$(cd "$(dirname "$__self")/../lib" && pwd)/proxy-common.sh" || { echo "proxy-docker: cannot load shared lib" >&2; exit 1; }
__pcu_init "${BASH_SOURCE[0]:-$0}"

STATE=""; DO_CLIENT=0; DO_DAEMON=0; RESTART=1
while [ $# -gt 0 ]; do
  case "$1" in
    on|proxy_yes) STATE=on ;;
    off|no_proxy) STATE=off ;;
    --client) DO_CLIENT=1 ;;
    --daemon) DO_DAEMON=1 ;;
    --all)    DO_CLIENT=1; DO_DAEMON=1 ;;
    --no-restart) RESTART=0 ;;
    -h|--help) sed -n '2,12p' "$PCU_SELF"; exit 0 ;;
    *) echo "proxy-docker: unknown arg '$1' (try -h)" >&2; exit 2 ;;
  esac; shift
done
[ -z "$STATE" ] && { echo "proxy-docker: need 'on' or 'off'" >&2; exit 2; }
[ $DO_CLIENT -eq 0 ] && [ $DO_DAEMON -eq 0 ] && DO_CLIENT=1   # default scope = client

__pcu_load_config
__pcu_warn_placeholder
command -v python3 >/dev/null 2>&1 || { echo "proxy-docker: python3 is required for JSON editing" >&2; exit 1; }
[ "$STATE" = on ] && [ -z "$HTTP_PROXY_URL" ] && { echo "proxy-docker: HTTP_PROXY_URL not set in $PCU_CONFIG" >&2; exit 1; }

# _json FILE STATE MODE HTTP HTTPS NOPROXY  (MODE = client|daemon) — atomic, merges.
_json() {
python3 - "$@" <<'PY'
import json, os, sys, tempfile
path, state, mode, http, https, noproxy = sys.argv[1:7]
try:
    with open(path) as f: data = json.load(f)
    if not isinstance(data, dict): data = {}
except Exception:
    data = {}
if mode == "client":
    keys = ("httpProxy", "httpsProxy", "noProxy")
    target = data.setdefault("proxies", {}).setdefault("default", {})
else:
    keys = ("http-proxy", "https-proxy", "no-proxy")
    target = data.setdefault("proxies", {})
if state == "on":
    for k, v in zip(keys, (http, https, noproxy)):
        if v: target[k] = v
else:
    for k in keys: target.pop(k, None)
    if mode == "client" and not target: data.get("proxies", {}).pop("default", None)
    if "proxies" in data and not data["proxies"]: data.pop("proxies", None)
d = os.path.dirname(path) or "."
os.makedirs(d, exist_ok=True)
fd, tmp = tempfile.mkstemp(dir=d)
with os.fdopen(fd, "w") as f:
    json.dump(data, f, indent=2); f.write("\n")
os.chmod(tmp, 0o644 if mode == "daemon" else 0o600)
os.replace(tmp, path)
print("  %s: docker %s proxy -> %s" % (path, mode, state))
PY
}

if [ $DO_CLIENT -eq 1 ]; then
  CJSON="${DOCKER_CLIENT_JSON:-$(__pcu_user_home)/.docker/config.json}"
  _json "$CJSON" "$STATE" client "$HTTP_PROXY_URL" "$HTTPS_PROXY_URL" "$NO_PROXY_LIST"
  if [ "$(id -u)" = 0 ] && [ -n "${SUDO_USER:-}" ] && [ -z "${DOCKER_CLIENT_JSON:-}" ]; then
    chown -R "$SUDO_USER" "$(__pcu_user_home)/.docker" 2>/dev/null || true
  fi
fi

if [ $DO_DAEMON -eq 1 ]; then
  DJSON="${DOCKER_DAEMON_JSON:-/etc/docker/daemon.json}"
  case "$DJSON" in
    /etc/*)
      if [ "$(id -u)" -ne 0 ]; then
        if [ "$RESTART" = 0 ]; then set -- --daemon --no-restart "$STATE"; else set -- --daemon "$STATE"; fi
        __pcu_need_root "write $DJSON ($STATE) and restart docker" "$@"
      fi ;;
  esac
  _json "$DJSON" "$STATE" daemon "$HTTP_PROXY_URL" "$HTTPS_PROXY_URL" "$NO_PROXY_LIST"
  if [ "$RESTART" = 1 ]; then
    echo "  restarting docker..."
    systemctl restart docker && echo "  docker restarted" || echo "  ! 'systemctl restart docker' failed — restart it yourself"
  else
    echo "  (skipped restart; apply with: sudo systemctl restart docker)"
  fi
fi
