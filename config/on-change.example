#!/usr/bin/env bash
# proxy-config-utility — optional on-change hook.
#
# proxy-detect runs this (if it exists and is executable) on every detection,
# passing the current status as $1: "proxy_yes" or "no_proxy". Use it for side
# effects that should follow the network state.
#
# It delegates to the per-tool modules for the side effects that DON'T need root:
#   - proxy-git    : git's global HTTP(S) proxy  (the generic replacement for an
#                    internal "configure my git proxy" tool like `dt`/devtool,
#                    which is NOT included in this repo)
#   - proxy-docker : Docker CLIENT proxy (build/run container env)
#
# Root-only tools (apt, snap, the Docker daemon) write /etc or system config and
# can't run from this unprivileged hook — toggle them deliberately (see below), or
# wire the passwordless-sudo recipes in their READMEs.
#
# Install:
#     cp config/on-change.example ~/.config/proxy-config/on-change
#     chmod +x ~/.config/proxy-config/on-change
#
# Keep it fast and non-interactive. proxy-detect ignores its output and errors.

set -u
status="${1:-no_proxy}"

command -v proxy-git    >/dev/null 2>&1 && proxy-git    "$status" >/dev/null 2>&1 || true
command -v proxy-docker >/dev/null 2>&1 && proxy-docker "$status" >/dev/null 2>&1 || true

# Root-only — run yourself when you change networks (or use sudoers automation).
# Use the FULL path: sudo's PATH excludes ~/bin.
#   proxy-apt  on|off              # /etc/apt/apt.conf.d/95proxy
#   proxy-snap on|off              # snap set system proxy.*
#   proxy-docker --daemon on|off   # /etc/docker/daemon.json (docker pull; restarts dockerd)
